# Postgres (matches docker-compose.yml defaults; host port 5433 → container 5432)
DATABASE_URL=postgresql+asyncpg://unravel:unravel@localhost:5544/unravel

# Phase 0 dev auth: when set, FastAPI accepts X-Dev-User header to inject a fake user.
# NEVER set this in production.
DEV_AUTH=1
DEV_USER_LOGIN=alice

# Anthropic — BYOK for AI chat panel (Phase 0)
ANTHROPIC_API_KEY=

# Session signing key (Phase 1+). Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=dev-only-change-me

# GitHub OAuth + App (Phase 1+ — leave empty for Phase 0)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_WEBHOOK_SECRET=

# Frontend → API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000
