# Postgres (matches docker-compose.yml defaults; host port 5433 → container 5432)
DATABASE_URL=postgresql+asyncpg://unravel:unravel@localhost:5544/unravel

# Phase 0 dev auth: when set, FastAPI accepts X-Dev-User header to inject a fake user.
# NEVER set this in production.
DEV_AUTH=1
DEV_USER_LOGIN=alice

# Anthropic — BYOK for AI chat panel (Phase 0)
ANTHROPIC_API_KEY=

# Session signing key (Phase 1+). Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=dev-only-change-me

# GitHub PAT fallback: used when no user is signed in (e.g. DEV_AUTH path or
# server-to-server). When OAuth is configured and a user is signed in, calls
# use that user's access token instead.
GITHUB_TOKEN=

# GitHub OAuth App — recommended path for real authorship + multi-user.
# Register at https://github.com/settings/applications/new with:
#   Homepage URL:           http://localhost:3000
#   Authorization callback: http://localhost:8000/auth/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Override the default scope (read:user user:email repo) if you want public-only:
# GITHUB_OAUTH_SCOPE=read:user user:email public_repo

# Where the API redirects after callback. Set to your FE origin.
WEB_BASE_URL=http://localhost:3000
# Where /auth/github builds its callback URL from.
API_BASE_URL=http://localhost:8000

# Cookie hardening (set to 1 when serving over HTTPS).
SESSION_COOKIE_SECURE=0
# SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_DOMAIN=

# GitHub App (Phase 2 — leave empty for now)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_WEBHOOK_SECRET=

# Frontend → API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000
